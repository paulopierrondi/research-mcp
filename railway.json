{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "dockerfile"
  },
  "deploy": {
    "startCommand": "node server.js",
    "numReplicas": 1,
    "restartPolicyMaxRetries": 5,
    "region": "us-west"
  },
  "env": {
    "PORT": "3000",
    "HISTORY_RETENTION_DAYS": "365",
    "OPENAI_API_KEY": "$OPENAI_API_KEY",
    "GOOGLE_API_KEY": "$GOOGLE_API_KEY"
  }
}
